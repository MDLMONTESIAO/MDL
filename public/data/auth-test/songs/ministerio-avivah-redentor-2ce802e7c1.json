  "html": "<u>[Intro] <i>F</i>  <i>C</i>  <i>G</i>\r\n\r\n</u><u>[Primeira Parte]\r\n\r\n</u><u><i>F</i>             <i>C</i>    <i>G</i>\r\n</u><u> A cruz vazia revelou\r\n</u><u><i>F</i>              <i>C</i> <i>G</i>\r\n</u><u> Que nada O parou\r\n</u><u><i>F</i>           <i>C</i>      <i>G</i>\r\n</u><u> Como filho nos tornou\r\n</u><u><i>F</i>              <i>C</i>     <i>G</i>\r\n</u><u> Ele é o nosso Redentor\r\n\r\n</u><u>[Refrão]\r\n\r\n</u><u><i>F</i>            <i>G</i>\r\n</u><u>Quem nos ama como Tu?\r\n</u><u> <i>Am</i>             <i>G</i>\r\n</u><u>Amor igual não há\r\n</u><u>  <i>F</i>           <i>G</i>\r\n</u><u>Jesus é Teu nosso louvor\r\n</u><u>     <i>C</i>           <i>G</i>\r\n</u><u>Pra sempre, pra sempre\r\n\r\n</u><u>[Segunda Parte]\r\n\r\n</u><u><i>F</i>             <i>C</i>      <i>G</i>\r\n</u><u> Desde o alto se rasgou\r\n</u><u><i>F</i>               <i>C</i>  <i>G</i>\r\n</u><u> O que nos separou\r\n</u><u><i>F</i>           <i>C</i>        <i>G</i>\r\n</u><u> Para ter acesso ao Pai\r\n</u><u><i>F</i>              <i>C</i> <i>G</i>\r\n</u><u> Justo nos tornou\r\n\r\n</u><u>( <i>F</i>  <i>G/C</i>  <i>Am</i>  <i>G</i> )\r\n\r\n</u><u>[Ponte]\r\n\r\n</u><u><i>F</i>              <i>G/C</i>\r\n</u><u> O céu se abrirá\r\n</u><u>     <i>Am</i>       <i>C</i>\r\n</u><u>O Cordeiro veremos\r\n</u><u><i>F</i>                <i>G/C</i>\r\n</u><u> Em Glória descerás\r\n</u><u>      <i>Am</i>       <i>G</i>\r\n</u><u>Porque Teu é o Reino\r\n\r\n</u><u><i>Final</i> <i>F</i>  <i>G</i>  <i>Am</i>  <i>G</i>  <i>C/E</i>\r\n</u><u>        <i>F</i>  <i>G</i>  <i>Am</i>  <i>G</i>  <i>C/E</i></u>"
